{
  "name": "wdio-native-demo-tests",
  "version": "1.0.0",
  "description": "Mobile test automation project for WDIO Native Demo App using WebDriverIO v9 + Appium v2",
  "private": true,
  "scripts": {
    "android": "wdio run config/wdio.android.conf.ts",
    "ios": "wdio run config/wdio.ios.conf.ts",
    "android:bs": "wdio run config/wdio.android.bs.conf.ts",
    "ios:bs": "wdio run config/wdio.ios.bs.conf.ts",
    "android:smoke": "wdio run config/wdio.android.conf.ts --mochaOpts.grep @smoke",
    "android:regression": "wdio run config/wdio.android.conf.ts --mochaOpts.grep @regression",
    "android:e2e": "wdio run config/wdio.android.conf.ts --mochaOpts.grep @e2e",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "lint": "eslint test/**/*.ts",
    "clean": "rm -rf allure-results allure-report screenshots/*.png"
  },
  "devDependencies": {
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/browserstack-service": "^9.0.0",
    "appium": "^2.0.0",
    "appium-uiautomator2-driver": "^4.0.0",
    "appium-xcuitest-driver": "^9.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.0.0",
    "@types/chai": "^4.0.0",
    "allure-commandline": "^2.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
